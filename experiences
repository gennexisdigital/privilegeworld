        <div class="listing-footer">
          <span class="listing-date">Apr 12, 2026</span>
          <span class="listing-price">$12,000 <span>/ pp</span></span>
        </div>
      </div>
    </a>

    <a href="#" class="listing-card">
      <div class="listing-img exp-img-3" data-icon="🎭">
        <div class="listing-img-inner exp-img-3"></div>
        <span class="spots-tag few">5 left</span>
      </div>
      <div class="listing-info">
        <div class="listing-location">Milan, Italy</div>
        <div class="listing-name">Private Opera Night — La Scala</div>
