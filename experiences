<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root { --black:#080808; --card:#1a1a1a; --border:rgba(255,255,255,0.08); --gold:#c9a96e; --gold-bright:#e8d5b0; --white:#f5f2ee; --muted:rgba(245,242,238,0.5); }
  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
  html, body { background: var(--black); color: var(--white); font-family:'Montserrat',sans-serif; font-weight:300; }

  section { max-width:1400px; margin:0 auto; padding:100px 48px; }
  .section-label { font-size:10px; font-weight:600; letter-spacing:0.3em; text-transform:uppercase; color:var(--gold);
    display:flex; align-items:center; gap:12px; margin-bottom:20px; }
  .section-label::after { content:''; flex:1; height:1px; background:var(--border); max-width:80px; }
  .section-title { font-family:'Cormorant Garamond',serif; font-size:clamp(36px,4vw,56px); font-weight:300; line-height:1.15; margin-bottom:16px; }
  .section-title em { font-style:italic; color:var(--gold); }

  .btn-outline { padding:10px 24px; border:1px solid var(--gold); color:var(--gold); font-size:10px; font-weight:600; letter-spacing:0.18em;
    text-transform:uppercase; text-decoration:none; transition: background 0.2s, color 0.2s; font-family:'Montserrat',sans-serif; cursor:pointer; background:transparent; display:inline-block; }
  .btn-outline:hover { background: var(--gold); color: var(--black); }

  .listings-header { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:48px; gap:20px; flex-wrap:wrap; }
  .cards-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:2px; }

  .listing-card { background:var(--card); position:relative; overflow:hidden; text-decoration:none; color:inherit; display:block;
    transition: transform 0.4s ease; }
  .listing-img { height:240px; position:relative; overflow:hidden; }
  .listing-img-inner { width:100%; height:100%; transition: transform 0.6s ease; position:relative; }
  .listing-card:hover .listing-img-inner { transform: scale(1.06); }

  /* Real event photos pulled from Reserved World */
  .exp-img-1 { background: url('https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/69a968bd3345c4492b2af5e8/d8f8e26ec_generated_image.png') center/cover no-repeat #1a1a1a; }
  .exp-img-2 { background: url('https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/69a968bd3345c4492b2af5e8/be11e68df_generated_image.png') center/cover no-repeat #1a1a1a; }
  .exp-img-3 { background: url('https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/69a968bd3345c4492b2af5e8/840eeb646_generated_image.png') center/cover no-repeat #1a1a1a; }
  .exp-img-4 { background: url('https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/69a968bd3345c4492b2af5e8/d8da7dc87_generated_image.png') center/cover no-repeat #1a1a1a; }

  /* subtle dark overlay so the spots-tag stays readable */
  .listing-img::before { content:''; position:absolute; inset:0; background: linear-gradient(180deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0) 70%, rgba(0,0,0,0.4) 100%); pointer-events:none; z-index:1; }
  .listing-img::after { display:none; }

  .tier-tag { position:absolute; top:16px; left:16px; font-size:9px; font-weight:700; letter-spacing:0.18em;
    text-transform:uppercase; padding:5px 11px; border-radius:2px; backdrop-filter: blur(6px); }
  .tier-circle { background: rgba(201,169,110,0.85); color: var(--black); }
  .tier-gold { background: rgba(232,213,176,0.9); color: var(--black); }
  .tier-black { background: rgba(122,74,214,0.85); color: var(--white); }

  .spots-tag { position:absolute; top:16px; right:16px; z-index:2; font-size:9px; font-weight:600; letter-spacing:0.15em;
    text-transform:uppercase; padding:5px 11px; background: rgba(8,8,8,0.7); color: var(--gold);
    backdrop-filter: blur(6px); border:1px solid rgba(201,169,110,0.4); }
  .spots-tag.few { color: #ff8080; border-color: rgba(255,128,128,0.4); }

  .listing-info { padding:22px 22px 26px; }
  .listing-location { font-size:10px; color:var(--gold); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:8px; }
  .listing-name { font-family:'Cormorant Garamond',serif; font-size:21px; font-weight:400; margin-bottom:14px; line-height:1.25; min-height:52px; }
  .listing-meta { display:flex; gap:16px; align-items:center; margin-bottom:16px; flex-wrap:wrap; }
  .listing-meta-item { font-size:10px; color:var(--muted); display:flex; align-items:center; gap:4px; }
  .listing-footer { display:flex; justify-content:space-between; align-items:flex-end; padding-top:14px; border-top:1px solid var(--border); }
  .listing-date { font-size:10px; color:var(--muted); letter-spacing:0.12em; text-transform:uppercase; }
  .listing-price { display:none; }
  .listing-footer { justify-content:flex-start; }

  @media (max-width:1100px){ .cards-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width:768px){ section{padding:72px 24px;} .cards-grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>
<section id="experiences">
  <div class="listings-header">
    <div>
      <div class="section-label">Featured Experiences</div>
      <h2 class="section-title">Extraordinary<br><em>Experiences</em></h2>
