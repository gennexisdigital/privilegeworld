          <span class="listing-meta-item">🛥 7 nights</span>
          <span class="listing-meta-item">👤 Full charter</span>
        </div>
        <div class="listing-footer">
          <span class="listing-date">Jun 15, 2026</span>
          <span class="listing-price">$95,000 <span>/ yacht</span></span>
        </div>
      </div>
    </a>

  </div>
</section>
</body>
</html>
